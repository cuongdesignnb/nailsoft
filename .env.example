NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://nailsoft:nailsoft@localhost:5432/nailsoft
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-high-entropy-secret-at-least-32-characters
IDENTITY_HASH_SECRET=replace-with-a-separate-high-entropy-secret
MFA_ENCRYPTION_KEY=replace-with-a-separate-high-entropy-key
NEXT_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
PUBLIC_BOOKING_ENABLED=true
OTP_PEPPER=development-only-replace-in-production
# Production requires OTP_PROVIDER=webhook and an HTTPS provider endpoint.
OTP_PROVIDER=development
OTP_PROVIDER_URL=
OTP_PROVIDER_TOKEN=
